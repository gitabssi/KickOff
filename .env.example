# KickOff Agent — copy to .env and fill in your values

# --- MongoDB Atlas (required) ---
# Create a free M0 cluster at https://cloud.mongodb.com, then paste the
# connection string from Connect → Drivers.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=kickoff
MONGODB_DB=kickoff

# --- Gemini / Vertex AI (required) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE
KICKOFF_MODEL=gemini-3-flash-preview
KICKOFF_PLANNER_MODEL=gemini-3-flash-preview

# --- Runtime mode ---
# local  = agents run in-process inside the gateway (best for development)
# cloud  = agents invoked on Vertex AI Agent Engine (after scripts/deploy_agents.py)
KICKOFF_AGENT_MODE=local

# --- MongoDB MCP server ---
# local  = agents spawn `npx -y mongodb-mcp-server` over stdio (needs Node 20+)
# http   = connect to a hosted MCP server (Cloud Run), set MCP_SERVER_URL
KICKOFF_MCP_MODE=local
MCP_SERVER_URL=

# --- Gateway ---
PORT=8080
